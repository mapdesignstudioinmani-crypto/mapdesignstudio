<style>

:root{
--primary:#0d2b45;
--accent:#1b4965;
--highlight:#ff7a00;
--white:#fff;
--light:#eef3f8;
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
font-family:'Poppins',sans-serif;
background:var(--primary);
color:white;
scroll-behavior:smooth;
}

/* NAV */
nav{
position:fixed;
top:0;
width:100%;
background:rgba(13,43,69,0.95);
padding:15px;
text-align:center;
z-index:1000;
}

nav a{
margin:0 15px;
color:white;
text-decoration:none;
font-weight:600;
}

nav a:hover{color:var(--highlight);}

/* HERO */
header{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.7)),url('images/project1.jpg') center/cover;
}

header h1{
font-size:50px;
}

header p{
margin-top:10px;
font-size:20px;
opacity:.9;
}

.btn{
margin-top:25px;
padding:14px 35px;
background:var(--highlight);
border-radius:30px;
color:white;
text-decoration:none;
font-weight:bold;
}

.btn:hover{background:#ff5500;}

/* SECTION */
section{
padding:80px 20px;
max-width:1100px;
margin:auto;
}

h2{
text-align:center;
margin-bottom:40px;
}

/* SERVICES */
.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:white;
color:#222;
padding:25px;
border-radius:15px;
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

/* PROJECTS */
.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:20px;
}

.gallery img{
width:100%;
border-radius:15px;
transition:.3s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* TESTIMONIAL */
.testimonial{
background:white;
color:#333;
padding:25px;
border-radius:15px;
margin-bottom:20px;
}

/* FAQ */
.faq{
background:white;
color:#333;
padding:20px;
margin-bottom:10px;
border-radius:10px;
}

/* CONTACT */
.contact{
background:white;
color:#333;
padding:30px;
border-radius:20px;
text-align:center;
}

input,textarea{
width:90%;
padding:12px;
margin:10px;
border-radius:8px;
border:none;
}

button{
padding:12px 30px;
background:var(--primary);
color:white;
border:none;
border-radius:25px;
cursor:pointer;
}

/* FLOAT BUTTONS */
.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
padding:12px 20px;
border-radius:30px;
text-decoration:none;
}

</style>
</head>

